COMPANY_NAME="Olffy"
SITE_NAME="Olffy"
SHOPIFY_REVALIDATION_SECRET=""
# Token Storefront publico compatible con Next Commerce.
SHOPIFY_STOREFRONT_ACCESS_TOKEN=""
# Usa este campo si tienes un token privado de Headless.
SHOPIFY_STOREFRONT_PRIVATE_ACCESS_TOKEN=""
# Solo si estas usando un token publico de Storefront.
SHOPIFY_STOREFRONT_PUBLIC_ACCESS_TOKEN=""
SHOPIFY_STORE_DOMAIN="tu-tienda.myshopify.com"
# Alias aceptado por compatibilidad si ya lo creaste en Vercel.
SHOPIFY_STORE_DOMINIO=""

# Admin API (para panel personalizado)
# Opcion 1: access token Admin directo.
SHOPIFY_ADMIN_API_ACCESS_TOKEN=""
# Opcion 2: credenciales de una app propia instalada (recomendado).
SHOPIFY_ADMIN_API_CLIENT_ID=""
SHOPIFY_ADMIN_API_CLIENT_SECRET=""
SHOPIFY_ADMIN_API_VERSION="2026-04"
ADMIN_PASSWORD="tu_contraseña"
# Alias aceptados por compatibilidad.
ADMIN_CONTRASENA=""
ADMIN_CONTRASEÑA=""

# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Solo backend. Nunca exponer con el prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=""
